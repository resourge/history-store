{
	"name": "@resourge/history-store",
	"version": "1.4.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"react-native": "./dist/index.native.js",
	"private": false,
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"javascript",
		"URLSearchParams",
		"react",
		"hooks",
		"typescript",
		"react-hooks",
		"react-search-params"
	],
	"files": [
		"dist"
	],
	"author": "resourge",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/resourge/history-store.git"
	},
	"exports": {
		".": {
			"default": "./dist/index.js",
			"react-native": "./dist/index.native.js"
		},
		"./mobile": {
			"default": "./dist/index.native.js"
		},
		"./utils": {
			"default": "./dist/index.utils.js"
		}
	},
	"typesVersions": {
		"*": {
			"index.d.ts": [
				"./dist/index.d.ts"
			],
			"mobile": [
				"./dist/index.native.d.ts"
			],
			"utils": [
				"./dist/index.utils.d.ts"
			]
		}
	},
	"scripts": {
		"commitizen": "git-cz",
		"commit": "git pull && git add . && npm run commitizen",
		"lint": "eslint \"./src/**/*.{ts,tsx}\"",
		"lint:prod": "cross-env NODE_ENV=production npm run lint",
		"dev": "vite",
		"build": "vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"semantic-release": "semantic-release"
	},
	"peerDependencies": {
		"react-native": "*",
		"react-native-url-polyfill": "*"
	},
	"peerDependenciesMeta": {
		"react-native": {
			"optional": true
		},
		"react-native-url-polyfill": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fastify/deepmerge": "^3.2.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"app-root-path": "^3.1.0",
		"cross-env": "^10.1.0",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-config-resourge": "^1.8.2",
		"glob": "^13.0.6",
		"jsdom": "^29.1.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-native": "^0.85.2",
		"react-native-url-polyfill": "^3.0.0",
		"rollup-plugin-cleanup": "^3.2.1",
		"semantic-release": "^25.0.3",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-checker": "^0.13.0",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.5"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
